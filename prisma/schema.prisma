generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "sqlite"
  url      = env("DATABASE_URL")
}

// Platform Admin (global system management)
model PlatformAdmin {
  id           String   @id @default(cuid())
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  @@map("platform_admins")
}

// Master Tenants (Corporate/Franchise Owners)
model MasterTenant {
  id            String   @id @default(cuid())
  corporateName String   @map("corporate_name")
  billingStatus String   @default("ACTIVE") @map("billing_status")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  tenants Tenant[]

  @@map("master_tenants")
}

// All Serving Locations (Standard Tenants & Sub-Tenants)
model Tenant {
  id             String             @id @default(cuid())
  name           String
  masterTenantId String?            @map("master_tenant_id")
  planTier       String             @default("FREE") @map("plan_tier") // FREE, PRO, ENTERPRISE
  walletBalance  Int                @default(50000) @map("wallet_balance") // in cents
  brandingConfig String?            @map("branding_config") // JSON
  welcomeMessage String?            @map("welcome_message")
  logoUrl        String?            @map("logo_url")
  contactEmail   String?            @map("contact_email")
  contactPhone   String?            @map("contact_phone")
  address        String?
  isActive       Boolean            @default(true) @map("is_active")
  createdAt      DateTime           @default(now()) @map("created_at")
  updatedAt      DateTime           @updatedAt @map("updated_at")

  masterTenant     MasterTenant?     @relation(fields: [masterTenantId], references: [id])
  users            StaffUser[]
  queues           Queue[]
  tickets          Ticket[]
  usageLedgers     UsageLedger[]
  serviceLogs      ServiceLog[]
  transactions     Transaction[]
  notifications    PushSubscription[]
  serviceWindows   ServiceWindow[]
  feedbacks        Feedback[]
  appointments     Appointment[]
  webhooks         Webhook[]
  customerProfiles CustomerProfile[]

  @@map("tenants")
}

// Staff Users (Managers & Agents)
model StaffUser {
  id           String   @id @default(cuid())
  tenantId     String   @map("tenant_id")
  email        String   @unique
  name         String
  passwordHash String   @map("password_hash")
  role         String   @default("AGENT") // MANAGER or AGENT
  isActive     Boolean  @default(true) @map("is_active")
  createdAt    DateTime @default(now()) @map("created_at")
  updatedAt    DateTime @updatedAt @map("updated_at")

  tenant      Tenant       @relation(fields: [tenantId], references: [id])
  serviceLogs ServiceLog[]

  @@map("users")
}

// Queues (Service Lines)
model Queue {
  id                    String          @id @default(cuid())
  tenantId              String          @map("tenant_id")
  name                  String
  description           String?
  defaultServiceTimeSec Int             @default(300) @map("default_service_time_sec")
  prefix                String          @default("A")
  currentSerial         Int             @default(0) @map("current_serial")
  nowServingSerial      Int             @default(0) @map("now_serving_serial")
  isActive              Boolean         @default(true) @map("is_active")
  createdAt             DateTime        @default(now()) @map("created_at")
  updatedAt             DateTime        @updatedAt @map("updated_at")

  tenant         Tenant          @relation(fields: [tenantId], references: [id])
  tickets        Ticket[]
  serviceWindows ServiceWindow[]
  appointments   Appointment[]

  @@index([tenantId, isActive])
  @@map("queues")
}

// Tickets
model Ticket {
  id            String    @id @default(cuid())
  tenantId      String    @map("tenant_id")
  queueId       String    @map("queue_id")
  serialNumber  Int       @map("serial_number")
  status        String    @default("WAITING") // WAITING, SERVING, COMPLETED, SKIPPED, CANCELLED
  customerName  String    @map("customer_name")
  customerPhone String?   @map("customer_phone")
  deviceId      String?   @map("device_id")
  notes         String?
  servedByAgent String?   @map("served_by_agent")
  skipCount     Int       @default(0) @map("skip_count")
  createdAt     DateTime  @default(now()) @map("created_at")
  servedAt      DateTime? @map("served_at")
  completedAt   DateTime? @map("completed_at")
  cancelledAt   DateTime? @map("cancelled_at")
  skippedAt     DateTime? @map("skipped_at")

  tenant     Tenant       @relation(fields: [tenantId], references: [id])
  queue      Queue        @relation(fields: [queueId], references: [id])
  ledger     UsageLedger?
  feedbacks  Feedback[]
  appointment Appointment?

  @@index([tenantId, status])
  @@index([queueId, status, serialNumber])
  @@index([customerPhone, tenantId])
  @@map("tickets")
}

// Billing Ledger (Pay-Per-Entry)
model UsageLedger {
  id         String   @id @default(cuid())
  tenantId   String   @map("tenant_id")
  ticketId   String   @unique @map("ticket_id")
  costCents  Int      @default(100) @map("cost_cents")
  createdAt  DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([tenantId, createdAt])
  @@map("usage_ledger")
}

// Service Logs (For EWT Calculation)
model ServiceLog {
  id              String   @id @default(cuid())
  tenantId        String   @map("tenant_id")
  queueId         String   @map("queue_id")
  agentId         String?  @map("agent_id")
  ticketId        String   @map("ticket_id")
  durationSeconds Int?     @map("duration_seconds")
  createdAt       DateTime @default(now()) @map("created_at")

  tenant Tenant      @relation(fields: [tenantId], references: [id])
  agent  StaffUser?  @relation(fields: [agentId], references: [id])

  @@index([tenantId, queueId, createdAt])
  @@map("service_logs")
}

// Wallet Transactions (B16: Payment history)
model Transaction {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  type        String   // TOP_UP, TICKET_CHARGE, REFUND, PAYMENT
  amountCents Int      @map("amount_cents") // positive for credit, negative for debit
  description String?
  createdBy   String?  @map("created_by") // userId who triggered
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, createdAt])
  @@map("transactions")
}

// Web Push Subscriptions (B3: Push notifications)
model PushSubscription {
  id        String   @id @default(cuid())
  tenantId  String   @map("tenant_id")
  ticketId  String?  @map("ticket_id")
  endpoint  String   @unique
  keysJson  String   @map("keys_json") // JSON: { p256dh, auth }
  createdAt DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@index([tenantId, ticketId])
  @@map("push_subscriptions")
}

// Audit Log (Platform admin action tracking)
model AuditLog {
  id        String   @id @default(cuid())
  userId    String?  @map("user_id")
  userType  String   @default("staff") // staff, platform_admin
  action    String   // LOGIN, TENANT_CREATE, QUEUE_UPDATE, etc.
  details   String?  // JSON
  ipAddress String?  @map("ip_address")
  createdAt DateTime @default(now()) @map("created_at")

  @@index([userId, createdAt])
  @@map("audit_logs")
}

// Plan Tier Limits
model PlanLimit {
  id              String   @id @default(cuid())
  planTier        String   @unique @map("plan_tier")
  maxQueues       Int      @default(2) @map("max_queues")
  maxStaff        Int      @default(3) @map("max_staff")
  maxTicketsPerDay Int     @default(50) @map("max_tickets_per_day")
  priceMonthlyCents Int    @default(0) @map("price_monthly_cents")

  @@map("plan_limits")
}

// ─── NEW MODELS (Section J) ──────────────────────────────────

// MF-01: Service Windows (configurable operating hours)
model ServiceWindow {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  queueId     String?  @map("queue_id")   // null = applies to all queues
  dayOfWeek   Int      @map("day_of_week") // 0=Sun, 1=Mon, ..., 6=Sat
  openTime    String   @map("open_time")   // HH:mm
  closeTime   String   @map("close_time")  // HH:mm
  isClosed    Boolean  @default(false) @map("is_closed") // true = closed that day
  isActive    Boolean  @default(true) @map("is_active")
  createdAt   DateTime @default(now()) @map("created_at")
  updatedAt   DateTime @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  queue  Queue?  @relation(fields: [queueId], references: [id])

  @@index([tenantId, dayOfWeek])
  @@map("service_windows")
}

// MF-10: Customer Feedback (post-service ratings)
model Feedback {
  id          String   @id @default(cuid())
  tenantId    String   @map("tenant_id")
  ticketId    String   @map("ticket_id")
  rating      Int                         // 1-5 stars
  comment     String?
  createdAt   DateTime @default(now()) @map("created_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  ticket Ticket @relation(fields: [ticketId], references: [id])

  @@index([tenantId, createdAt])
  @@map("feedback")
}

// MF-11: Appointments (scheduled time slots)
model Appointment {
  id              String    @id @default(cuid())
  tenantId        String    @map("tenant_id")
  queueId         String    @map("queue_id")
  customerName    String    @map("customer_name")
  customerPhone   String?   @map("customer_phone")
  scheduledDate   String    @map("scheduled_date") // YYYY-MM-DD
  scheduledTime   String    @map("scheduled_time") // HH:mm
  status          String    @default("SCHEDULED") // SCHEDULED, CHECKED_IN, SERVING, COMPLETED, CANCELLED, NO_SHOW
  notes           String?
  ticketId        String?   @unique @map("ticket_id") // linked when converted to ticket
  createdAt       DateTime  @default(now()) @map("created_at")
  updatedAt       DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])
  queue  Queue  @relation(fields: [queueId], references: [id])
  ticket Ticket? @relation(fields: [ticketId], references: [id])

  @@index([tenantId, scheduledDate, status])
  @@index([customerPhone, tenantId])
  @@map("appointments")
}

// MF-14: Webhooks (external integrations)
model Webhook {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  url              String
  events           String    @map("events") // JSON array: ["TICKET_CREATED","TICKET_CALLED",...]
  secret           String
  isActive         Boolean   @default(true) @map("is_active")
  successCount     Int       @default(0) @map("success_count")
  failureCount     Int       @default(0) @map("failure_count")
  lastTriggeredAt  DateTime? @map("last_triggered_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@map("webhooks")
}

// MF-12: Customer Profiles (repeat customer recognition)
model CustomerProfile {
  id               String    @id @default(cuid())
  tenantId         String    @map("tenant_id")
  phone            String
  name             String?
  totalVisits      Int       @default(0) @map("total_visits")
  totalTickets     Int       @default(0) @map("total_tickets")
  completedTickets Int       @default(0) @map("completed_tickets")
  avgServiceTime   Int?      @map("avg_service_time") // seconds
  lastVisitAt      DateTime? @map("last_visit_at")
  createdAt        DateTime  @default(now()) @map("created_at")
  updatedAt        DateTime  @updatedAt @map("updated_at")

  tenant Tenant @relation(fields: [tenantId], references: [id])

  @@unique([tenantId, phone])
  @@index([tenantId, totalVisits])
  @@map("customer_profiles")
}